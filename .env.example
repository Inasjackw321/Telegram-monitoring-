# --- Telegram API credentials (shared by both the Node app and the Python app) ---
# Get these from https://my.telegram.org -> "API development tools"
# (log in with the phone number of the account you want to monitor)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# --- Translation (shared by both apps) ---
# Target language for auto-translation (ISO 639-1 code, e.g. en, es, fr, ar)
TRANSLATE_TARGET_LANG=en

# Recommended: Anthropic API key for the best translation quality (Claude Haiku).
# Handles Persian/Arabic news idioms and political/military jargon far better
# than raw machine translation. Get a key at https://console.anthropic.com
# If left blank, falls back to DeepL (if configured below), then the free
# Google Translate endpoint.
ANTHROPIC_API_KEY=

# Optional: DeepL API key as a second-choice translation provider.
# Get a free key at https://www.deepl.com/pro-api
# If both this and ANTHROPIC_API_KEY are left blank, both apps fall back to
# the free Google Translate endpoint (no key needed, best-effort, may
# rate-limit under heavy load).
DEEPL_API_KEY=

# --- Monitoring scope (shared by both apps) ---
# Both apps only monitor channels/groups your account is already a member of
# - nothing is auto-joined. To monitor a new channel, join it in Telegram
# yourself first, then restart the app.

# On startup, each monitored channel's recent history is loaded so the
# timeline isn't empty until new messages happen to arrive. Set
# BACKFILL_LIMIT=0 to disable and only show messages sent after the app starts.
BACKFILL_LIMIT=15
BACKFILL_HOURS=24

# =========================================================================
# --- Node app (server/) ---
# =========================================================================

# Where the login session string is stored after running `npm run login`.
# Treat this file like a password - anyone with it can access the Telegram account.
TELEGRAM_SESSION_FILE=./server/data/session.txt

PORT=4000

# Where downloaded photos/videos from monitored channels are stored and served from.
MEDIA_DIR=./server/media

# =========================================================================
# --- Python app (python-app/) ---
# =========================================================================

# Telethon session file (created on first run - it will prompt you to log in).
# Treat this like a password too.
PY_SESSION_FILE=./python-app/data/session

PY_PORT=4300

PY_MEDIA_DIR=./python-app/media
